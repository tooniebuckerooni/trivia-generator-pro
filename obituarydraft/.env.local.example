# Copy this file to .env.local and fill in your keys.

# Required — your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Stripe. Without these, the paywall shows but checkout returns a
# friendly "not configured" message. With them, the "Subscribe" button opens
# a real Stripe Checkout session for the $49/month plan.
STRIPE_SECRET_KEY=sk_test_...
# Optional: a pre-created recurring Price ID ($49/month). If omitted, the
# checkout route creates an inline $49/month price automatically.
STRIPE_PRICE_ID=price_...
